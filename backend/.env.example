# Servidor backend
PORT=4000
CLIENT_URL=http://localhost:5173

# Base de datos unica del proyecto
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=turn0_db

# Configuracion SMTP para enviar correos reales.
# Ejemplo Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=tu_correo@gmail.com, SMTP_PASS=clave_de_aplicacion
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TURN0 <no-reply@turn0.com>"

# Solo para el comando npm run test:mail.
# El registro normal siempre envia al correo escrito en la interfaz.
WELCOME_TEST_EMAIL=
